{
  "appName": "Summary Aggregate",
  "startPage": "home",
  "pages": {
    "home": {
      "component": "page",
      "title": "Home",
      "content": [
        {
          "component": "summary",
          "label": "Total Tasks",
          "value": "{COUNT(tasks)}"
        },
        {
          "component": "form",
          "id": "addForm",
          "dataSource": "tasks",
          "fields": [
            { "name": "title", "type": "text", "label": "Title", "required": true }
          ]
        },
        {
          "component": "button",
          "label": "Save",
          "onClick": [
            { "action": "submit", "dataSource": "tasks", "target": "addForm" }
          ]
        }
      ]
    }
  },
  "dataSources": {
    "tasks": {
      "url": "local://tasks",
      "method": "POST",
      "fields": [
        { "name": "title", "type": "text" }
      ]
    }
  }
}

{
  "appName": "Current User Defaults",
  "startPage": "home",
  "auth": {
    "multiUser": true,
    "selfRegistration": true
  },
  "pages": {
    "home": {
      "component": "page",
      "title": "Home",
      "content": [
        {
          "component": "form",
          "id": "noteForm",
          "dataSource": "notes",
          "fields": [
            { "name": "author", "type": "text", "label": "Author", "default": "CURRENT_USER.EMAIL" },
            { "name": "name", "type": "text", "label": "Name", "default": "CURRENT_USER.NAME" },
            { "name": "body", "type": "text", "label": "Body" }
          ]
        }
      ]
    }
  },
  "dataSources": {
    "notes": {
      "url": "local://notes",
      "method": "POST",
      "fields": [
        { "name": "author", "type": "text" },
        { "name": "name", "type": "text" },
        { "name": "body", "type": "text" }
      ]
    }
  }
}

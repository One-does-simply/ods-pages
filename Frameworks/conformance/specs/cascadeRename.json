{
  "appName": "Cascade Rename",
  "startPage": "home",
  "pages": {
    "home": {
      "component": "page",
      "title": "Home",
      "content": [
        {
          "component": "button",
          "label": "Rename Work to Projects",
          "onClick": [
            {
              "action": "update",
              "dataSource": "categories",
              "matchField": "id",
              "target": "c1",
              "withData": { "name": "Projects" },
              "cascade": {
                "childDataSource": "tasks",
                "childLinkField": "category",
                "parentField": "name"
              }
            }
          ]
        }
      ]
    }
  },
  "dataSources": {
    "categories": {
      "url": "local://categories",
      "method": "POST",
      "fields": [
        { "name": "id", "type": "text" },
        { "name": "name", "type": "text" }
      ],
      "seedData": [
        { "id": "c1", "name": "Work" },
        { "id": "c2", "name": "Home" }
      ]
    },
    "tasks": {
      "url": "local://tasks",
      "method": "POST",
      "fields": [
        { "name": "title", "type": "text" },
        { "name": "category", "type": "text" }
      ],
      "seedData": [
        { "title": "t1", "category": "Work" },
        { "title": "t2", "category": "Work" },
        { "title": "t3", "category": "Home" }
      ]
    }
  }
}

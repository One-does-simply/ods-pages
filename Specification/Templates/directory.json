{
  "templateName": "Directory",
  "description": "A searchable directory with card layout and detail view. Browse, search, and manage contacts or members.",
  "icon": "people",
  "questions": [
    {
      "id": "appName",
      "label": "What do you want to call your app?",
      "type": "text",
      "required": true,
      "placeholder": "e.g., Team Directory, Vendor Contacts"
    },
    {
      "id": "entryName",
      "label": "What's each entry called?",
      "type": "text",
      "required": true,
      "placeholder": "e.g., Contact, Member, Vendor"
    },
    {
      "id": "fields",
      "label": "What info do you want to store?",
      "type": "field-list",
      "required": true,
      "presets": [
        {
          "label": "Name",
          "name": "name",
          "type": "text"
        },
        {
          "label": "Email",
          "name": "email",
          "type": "email"
        },
        {
          "label": "Phone",
          "name": "phone",
          "type": "text"
        },
        {
          "label": "Role",
          "name": "role",
          "type": "text"
        },
        {
          "label": "Department",
          "name": "department",
          "type": "select",
          "options": [
            "General"
          ]
        },
        {
          "label": "Location",
          "name": "location",
          "type": "text"
        },
        {
          "label": "Notes",
          "name": "notes",
          "type": "multiline"
        }
      ]
    },
    {
      "id": "theme",
      "label": "App theme",
      "type": "select",
      "options": ["indigo", "slate", "ocean", "parchment", "peach", "terracotta", "walnut", "cupcake", "bumblebee", "emerald", "corporate", "synthwave", "retro", "cyberpunk", "valentine", "halloween", "garden", "forest", "aqua", "lofi", "pastel", "fantasy", "wireframe", "black", "luxury", "dracula", "cmyk", "autumn", "business", "acid", "lemonade", "night", "coffee", "winter", "dim", "nord", "sunset", "caramellatte", "abyss", "silk"],
      "default": "indigo"
    }
  ],
  "template": {
    "appName": "${appName}",
    "branding": {
      "theme": "${theme}"
    },
    "startPage": "directoryPage",
    "menu": [
      {
        "label": "Directory",
        "mapsTo": "directoryPage"
      },
      {
        "label": "Add ${entryName}",
        "mapsTo": "addPage"
      }
    ],
    "pages": {
      "directoryPage": {
        "component": "page",
        "title": "${appName}",
        "content": [
          {
            "component": "summary",
            "label": "Total ${entryName}s",
            "value": "{COUNT(entriesReader)}",
            "icon": "people",
            "styleHint": {
              "color": "info"
            }
          },
          {
            "component": "text",
            "content": "No entries yet. Add your first ${entryName} to get started!",
            "styleHint": {
              "variant": "body",
              "align": "center",
              "color": "grey"
            },
            "visibleWhen": {
              "source": "entriesReader",
              "countEquals": 0
            }
          },
          {
            "component": "list",
            "dataSource": "entriesReader",
            "searchable": true,
            "displayAs": "cards",
            "columns": {
              "$map": "fields",
              "each(field)": {
                "$if": "field.type == 'select'",
                "then": {
                  "header": "${field.label}",
                  "field": "${field.name}",
                  "sortable": true,
                  "filterable": true
                },
                "else": {
                  "header": "${field.label}",
                  "field": "${field.name}",
                  "sortable": true
                }
              }
            },
            "rowActions": [
              {
                "label": "Delete",
                "action": "delete",
                "dataSource": "entriesDeleter",
                "matchField": "_id"
              }
            ],
            "onRowTap": {
              "action": "navigate",
              "target": "editPage",
              "populateForm": "editForm"
            }
          },
          {
            "component": "button",
            "label": "Add ${entryName}",
            "onClick": [
              {
                "action": "navigate",
                "target": "addPage"
              }
            ],
            "styleHint": {
              "emphasis": "primary",
              "icon": "add_circle"
            }
          }
        ]
      },
      "addPage": {
        "component": "page",
        "title": "Add ${entryName}",
        "content": [
          {
            "component": "text",
            "content": "Add a new ${entryName} to the directory.",
            "styleHint": {
              "variant": "body"
            }
          },
          {
            "component": "form",
            "id": "addForm",
            "fields": {
              "$map": "fields",
              "each(field)": {
                "$if": "field.type == 'select'",
                "then": {
                  "name": "${field.name}",
                  "label": "${field.label}",
                  "type": "select",
                  "options": {
                    "$eval": "field.options"
                  }
                },
                "else": {
                  "name": "${field.name}",
                  "label": "${field.label}",
                  "type": "${field.type}"
                }
              }
            }
          },
          {
            "component": "button",
            "label": "Save",
            "onClick": [
              {
                "action": "submit",
                "dataSource": "entriesStore",
                "target": "addForm"
              },
              {
                "action": "navigate",
                "target": "directoryPage"
              },
              {
                "action": "showMessage",
                "message": "${entryName} added!"
              }
            ],
            "styleHint": {
              "emphasis": "primary",
              "icon": "save"
            }
          }
        ]
      },
      "editPage": {
        "component": "page",
        "title": "Edit ${entryName}",
        "content": [
          {
            "component": "form",
            "id": "editForm",
            "fields": {
              "$map": "fields",
              "each(field)": {
                "$if": "field.type == 'select'",
                "then": {
                  "name": "${field.name}",
                  "label": "${field.label}",
                  "type": "select",
                  "options": {
                    "$eval": "field.options"
                  }
                },
                "else": {
                  "name": "${field.name}",
                  "label": "${field.label}",
                  "type": "${field.type}"
                }
              }
            }
          },
          {
            "component": "button",
            "label": "Save Changes",
            "onClick": [
              {
                "action": "update",
                "dataSource": "entriesUpdater",
                "target": "editForm",
                "matchField": "_id"
              },
              {
                "action": "navigate",
                "target": "directoryPage"
              },
              {
                "action": "showMessage",
                "message": "${entryName} updated!"
              }
            ],
            "styleHint": {
              "emphasis": "primary",
              "icon": "save"
            }
          },
          {
            "component": "button",
            "label": "Back",
            "onClick": [
              {
                "action": "navigate",
                "target": "directoryPage"
              }
            ],
            "styleHint": {
              "emphasis": "secondary",
              "icon": "arrow_back",
              "variant": "outlined"
            }
          }
        ]
      }
    },
    "dataSources": {
      "entriesStore": {
        "url": "local://directory",
        "method": "POST"
      },
      "entriesReader": {
        "url": "local://directory",
        "method": "GET",
        "fields": {
          "$map": "fields",
          "each(field)": {
            "name": "${field.name}",
            "type": "${field.type}"
          }
        }
      },
      "entriesUpdater": {
        "url": "local://directory",
        "method": "PUT"
      },
      "entriesDeleter": {
        "url": "local://directory",
        "method": "DELETE"
      }
    },
    "help": {
      "overview": "${appName} is your searchable directory for ${entryName}s. Browse entries as cards, tap to view or edit details, and use the search bar to find anyone quickly. All data stays on your device."
    }
  }
}
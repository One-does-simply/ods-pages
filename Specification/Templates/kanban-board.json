{
  "templateName": "Kanban Board",
  "description": "A drag-and-drop task board with customizable columns. Track items through stages like To Do, In Progress, and Done.",
  "icon": "dashboard",
  "questions": [
    {
      "id": "appName",
      "label": "What do you want to call your app?",
      "type": "text",
      "required": true,
      "placeholder": "e.g., Project Board, Sprint Tracker, Hiring Pipeline"
    },
    {
      "id": "itemName",
      "label": "What are the items on the board called?",
      "type": "text",
      "required": true,
      "placeholder": "e.g., Task, Ticket, Card, Candidate"
    },
    {
      "id": "columns",
      "label": "What are your board columns? (comma-separated)",
      "type": "text",
      "required": true,
      "placeholder": "e.g., To Do, In Progress, Review, Done",
      "default": "To Do, In Progress, Review, Done"
    },
    {
      "id": "fields",
      "label": "What info goes on each card?",
      "type": "field-list",
      "required": true,
      "presets": [
        { "label": "Title", "name": "title", "type": "text" },
        { "label": "Assignee", "name": "assignee", "type": "user" },
        { "label": "Priority", "name": "priority", "type": "select", "options": ["Low", "Medium", "High", "Urgent"] },
        { "label": "Due Date", "name": "dueDate", "type": "date" },
        { "label": "Description", "name": "description", "type": "multiline" }
      ]
    },
    {
      "id": "theme",
      "label": "App theme",
      "type": "select",
      "options": ["indigo", "slate", "ocean", "parchment", "peach", "terracotta", "walnut", "cupcake", "bumblebee", "emerald", "corporate", "synthwave", "retro", "cyberpunk", "valentine", "halloween", "garden", "forest", "aqua", "lofi", "pastel", "fantasy", "wireframe", "black", "luxury", "dracula", "cmyk", "autumn", "business", "acid", "lemonade", "night", "coffee", "winter", "dim", "nord", "sunset", "caramellatte", "abyss", "silk"],
      "default": "indigo"
    }
  ],
  "template": {
    "appName": "${appName}",
    "branding": { "theme": "${theme}" },
    "startPage": "boardPage",
    "menu": [
      { "label": "Board", "mapsTo": "boardPage" },
      { "label": "Add ${itemName}", "mapsTo": "addPage" },
      { "label": "All ${itemName}s", "mapsTo": "listPage" }
    ],
    "pages": {
      "boardPage": {
        "component": "page",
        "title": "${appName}",
        "content": [
          {
            "component": "kanban",
            "dataSource": "itemsReader",
            "statusField": "status",
            "titleField": {
              "$if": "fields",
              "then": "${fields[0].name}",
              "else": "title"
            },
            "cardFields": {
              "$if": "fields",
              "then": {
                "$map": "fields",
                "each(field)": "${field.name}"
              },
              "else": ["title"]
            },
            "searchable": true,
            "rowActions": [
              {
                "label": "Delete",
                "action": "delete",
                "dataSource": "itemsDeleter",
                "matchField": "_id",
                "confirm": "Delete this ${itemName}?"
              }
            ]
          }
        ]
      },
      "addPage": {
        "component": "page",
        "title": "Add ${itemName}",
        "content": [
          {
            "component": "form",
            "id": "addForm",
            "fields": {
              "$flatten": [
                {
                  "$if": "fields",
                  "then": {
                    "$map": "fields",
                    "each(field)": {
                      "$if": "field.type == 'select'",
                      "then": {
                        "name": "${field.name}",
                        "label": "${field.label}",
                        "type": "select",
                        "required": true,
                        "options": { "$eval": "field.options" }
                      },
                      "else": {
                        "$if": "field.type == 'date'",
                        "then": {
                          "name": "${field.name}",
                          "label": "${field.label}",
                          "type": "date",
                          "default": "+7d"
                        },
                        "else": {
                          "name": "${field.name}",
                          "label": "${field.label}",
                          "type": "${field.type}",
                          "required": "${field.name == fields[0].name}"
                        }
                      }
                    }
                  },
                  "else": []
                },
                [
                  {
                    "name": "status",
                    "label": "Status",
                    "type": "select",
                    "required": true,
                    "default": "${columns[0]}",
                    "options": { "$eval": "columns" }
                  }
                ]
              ]
            }
          },
          {
            "component": "button",
            "label": "Add ${itemName}",
            "onClick": [
              { "action": "submit", "dataSource": "itemsStore", "target": "addForm" },
              { "action": "navigate", "target": "boardPage" },
              { "action": "showMessage", "message": "${itemName} added!" }
            ],
            "styleHint": { "emphasis": "primary" }
          }
        ]
      },
      "listPage": {
        "component": "page",
        "title": "All ${itemName}s",
        "content": [
          {
            "component": "list",
            "dataSource": "itemsReader",
            "searchable": true,
            "columns": {
              "$flatten": [
                {
                  "$if": "fields",
                  "then": {
                    "$map": "fields",
                    "each(field)": {
                      "$if": "field.type == 'select'",
                      "then": {
                        "header": "${field.label}",
                        "field": "${field.name}",
                        "sortable": true,
                        "filterable": true
                      },
                      "else": {
                        "header": "${field.label}",
                        "field": "${field.name}",
                        "sortable": true
                      }
                    }
                  },
                  "else": []
                },
                [
                  {
                    "header": "Status",
                    "field": "status",
                    "sortable": true,
                    "filterable": true
                  }
                ]
              ]
            },
            "rowActions": [
              {
                "label": "Delete",
                "action": "delete",
                "dataSource": "itemsDeleter",
                "matchField": "_id"
              }
            ]
          }
        ]
      }
    },
    "dataSources": {
      "itemsStore": { "url": "local://items", "method": "POST" },
      "itemsReader": {
        "url": "local://items",
        "method": "GET",
        "fields": {
          "$flatten": [
            {
              "$if": "fields",
              "then": {
                "$map": "fields",
                "each(field)": {
                  "$if": "field.type == 'select'",
                  "then": {
                    "name": "${field.name}",
                    "type": "select",
                    "options": { "$eval": "field.options" }
                  },
                  "else": {
                    "name": "${field.name}",
                    "type": "${field.type}"
                  }
                }
              },
              "else": []
            },
            [
              {
                "name": "status",
                "type": "select",
                "options": { "$eval": "columns" }
              }
            ]
          ]
        }
      },
      "itemsUpdater": { "url": "local://items", "method": "PUT" },
      "itemsDeleter": { "url": "local://items", "method": "DELETE" }
    },
    "help": {
      "overview": "${appName} is a kanban board for tracking ${itemName}s. Drag cards between columns to update their status. Use the Add page to create new ${itemName}s, or view everything in a table on the All ${itemName}s page.",
      "pages": {
        "boardPage": "Drag ${itemName}s between columns to change their status. Tap a card to see details.",
        "addPage": "Fill out the form to create a new ${itemName}.",
        "listPage": "View all ${itemName}s in a sortable, searchable table."
      }
    },
    "tour": [
      { "title": "Welcome to ${appName}!", "content": "Track your ${itemName}s on a visual kanban board.", "page": "boardPage" },
      { "title": "Drag and Drop", "content": "Move cards between columns to update their status. It's that simple.", "page": "boardPage" },
      { "title": "Add ${itemName}s", "content": "Use this form to add new ${itemName}s to the board.", "page": "addPage" },
      { "title": "You're Ready!", "content": "Start managing your ${itemName}s now." }
    ]
  }
}
